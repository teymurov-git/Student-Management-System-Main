DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://*.vercel.app,http://localhost:3000,http://127.0.0.1:8000
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-this-password
DJANGO_SUPERUSER_EMAIL=admin@example.com

# --- Davamlı verilənlər (Vercel / production) ---
# Layihə Django ORM ilə işləyir (Prisma yoxdur). Vercel-də məlumatın qalması üçün
# idarə olunan PostgreSQL təyin edin və aşağıdakı DATABASE_URL-i Vercel Environment
# Variables-ə əlavə edin. Olmadıqda Vercel SQLite faylını /tmp-də saxlayır — deploy
# və ya soyuq başlanğıcdan sonra itkisi gözləniləndir.
#
# Vercel Postgres / Marketplace: çox vaxt avtomatik POSTGRES_URL yaradılır — layihə
# onu DATABASE_URL kimi də istifadə edir (əlavə kopyalama lazım olmaya bilər).
# Əks halda connection string-i DATABASE_URL adı ilə əlavə edin (sslmode=require).
#
# Neon / Supabase: layihə panelindən connection string (postgres:// və ya postgresql://).
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Serverless üçün əlaqənin hər sorğudan sonra bağlanması (default: Vercel-də 0, lokalda 600).
# DATABASE_CONN_MAX_AGE=0

# Vercel-də default true: bulud Postgres üçün SSL. Lokal Postgres SSL-sizdirsə false edin.
# DATABASE_SSL_REQUIRE=false
